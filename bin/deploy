#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
[ -f "$SCRIPT_DIR/../.env.deploy" ] && source "$SCRIPT_DIR/../.env.deploy"

VPS_USER="${DEPLOY_USER}"
VPS_HOST="${DEPLOY_HOST}"
VPS_PORT="${DEPLOY_PORT}"
APP_DIR="${DEPLOY_PATH}"
SERVICE_NAME="${DEPLOY_SERVICE}"

if [[ -z "$VPS_HOST" || -z "$APP_DIR" || -z "$SERVICE_NAME" ]]; then
echo "❌ Missing required env vars. Copy .env.deploy.example to .env.deploy and fill it in."
exit 1
fi

echo "🚀 Deploying to $VPS_HOST..."

ssh -p $VPS_PORT $VPS_USER@$VPS_HOST bash -l -s << EOF
set -e
cd $APP_DIR

echo "📦 Pulling latest code..."
git pull origin main

echo "📦 Installing Node dependencies..."
yarn install --frozen-lockfile

echo "💎 Installing gems..."
RAILS_ENV=production bundle config set --local without 'development test'
RAILS_ENV=production bundle install

echo "🗄️ Running migrations..."
RAILS_ENV=production  bin/rails db:migrate RAILS_ENV=production

echo "🎨 Building Tailwind..."
RAILS_ENV=production  bin/rails tailwindcss:build

echo "⚙️ Precompiling assets..."
RAILS_ENV=production bin/rails assets:precompile

echo "🔄 Restarting Puma..."
sudo -n /usr/bin/systemctl restart $SERVICE_NAME
EOF

echo "✅ Deployed successfully!"