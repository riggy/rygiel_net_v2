<% content_for :title, "Referral Links" %>

<div class="flex items-center justify-between mb-7">
  <h1 class="text-xl font-bold tracking-[-0.02em]">Referral Links</h1>
  <%= link_to "New link", new_admin_referral_link_path, class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-accent text-white border border-accent hover:bg-accent-hover hover:border-accent-hover" %>
</div>

<% if @referral_links.any? %>
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Name</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border hidden md:table-cell">Slug</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border hidden md:table-cell">Target</th>
        <th class="text-right p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Clicks</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Status</th>
        <th class="border-b border-border"></th>
      </tr>
    </thead>
    <tbody>
      <% @referral_links.each do |link| %>
        <tr>
          <td class="p-3.5 border-b border-border text-surface font-medium"><%= link.name %></td>
          <td class="p-3.5 border-b border-border text-muted font-mono text-xs hidden md:table-cell">/go/<%= link.slug %></td>
          <td class="p-3.5 border-b border-border text-muted hidden md:table-cell"><%= link.target_path %></td>
          <td class="p-3.5 border-b border-border text-muted text-right"><%= link.clicks %></td>
          <td class="p-3.5 border-b border-border text-muted">
            <% if link.active? %>
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">Active</span>
            <% else %>
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-card text-subtle border border-border">Inactive</span>
            <% end %>
          </td>
          <td class="p-3.5 border-b border-border">
            <div class="flex gap-2 justify-end">
              <%= link_to "Edit", edit_admin_referral_link_path(link), class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-transparent text-surface border border-border-hover hover:border-muted" %>
              <%= button_to "Delete", admin_referral_link_path(link), method: :delete, class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-transparent text-red-500 border border-[#2a1a1a] hover:bg-[#1a0a0a] hover:border-red-500", data: { turbo_confirm: "Delete \"#{link.name}\"?" } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-10">No referral links yet. <%= link_to "Create one", new_admin_referral_link_path %>.</p>
<% end %>
