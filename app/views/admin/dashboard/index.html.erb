<% content_for :title, "Dashboard" %>

<div class="mb-6">
  <h1 class="text-xl font-bold tracking-[-0.02em]">Dashboard</h1>
  <p class="text-subtle text-sm mt-1">Site overview</p>
</div>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

  <%# Blog Posts %>
  <div class="bg-card border border-border rounded-lg p-5 flex flex-col gap-4">
    <div class="flex items-center justify-between">
      <span class="text-xs font-semibold uppercase tracking-wider text-subtle">Blog Posts</span>
      <%= link_to "Manage →", admin_posts_path, class: "text-muted text-[0.75rem] hover:text-surface transition-colors" %>
    </div>

    <div class="flex gap-2">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">
        <%= @published_posts_count %> published
      </span>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-card text-subtle border border-border">
        <%= @draft_posts_count %> draft<%= "s" if @draft_posts_count != 1 %>
      </span>
    </div>

    <% if @latest_post %>
      <div class="flex-1">
        <p class="text-[0.75rem] text-subtle uppercase tracking-wider mb-1">Latest</p>
        <%= link_to edit_admin_post_path(@latest_post), class: "group block" do %>
          <p class="text-sm font-medium text-surface group-hover:text-accent transition-colors leading-snug"><%= @latest_post.title %></p>
          <p class="text-[0.75rem] text-muted mt-0.5"><%= @latest_post.published_at&.strftime("%b %-d, %Y") %></p>
        <% end %>
      </div>
    <% end %>

    <div class="mt-auto pt-2 border-t border-border">
      <%= link_to "New post →", new_admin_post_path, class: "text-accent text-[0.8125rem] font-medium hover:text-accent-hover transition-colors" %>
    </div>
  </div>

  <%# Now Page %>
  <div class="bg-card border border-border rounded-lg p-5 flex flex-col gap-4">
    <div class="flex items-center justify-between">
      <span class="text-xs font-semibold uppercase tracking-wider text-subtle">Now Page</span>
      <%= link_to "Manage →", admin_now_entries_path, class: "text-muted text-[0.75rem] hover:text-surface transition-colors" %>
    </div>

    <% if @latest_now_entry %>
      <div>
        <p class="text-[0.75rem] text-subtle uppercase tracking-wider mb-1">Last updated</p>
        <p class="text-sm font-medium text-surface"><%= @latest_now_entry.updated_at.strftime("%b %-d, %Y") %></p>
      </div>

      <div class="flex-1">
        <p class="text-[0.75rem] text-subtle uppercase tracking-wider mb-1">Latest entry</p>
        <%= link_to edit_admin_now_entry_path(@latest_now_entry), class: "group block" do %>
          <p class="text-sm text-muted group-hover:text-surface transition-colors leading-relaxed line-clamp-4">
            <%= truncate(strip_tags(@latest_now_entry.content), length: 160) %>
          </p>
        <% end %>
      </div>
    <% else %>
      <p class="text-subtle text-sm flex-1">No entries yet.</p>
    <% end %>

    <div class="mt-auto pt-2 border-t border-border">
      <%= link_to "New entry →", new_admin_now_entry_path, class: "text-accent text-[0.8125rem] font-medium hover:text-accent-hover transition-colors" %>
    </div>
  </div>

  <%# CV %>
  <div class="bg-card border border-border rounded-lg p-5 flex flex-col gap-4">
    <div class="flex items-center justify-between">
      <span class="text-xs font-semibold uppercase tracking-wider text-subtle">CV</span>
      <%= link_to "Edit →", edit_admin_curriculum_vitae_path, class: "text-muted text-[0.75rem] hover:text-surface transition-colors" %>
    </div>

    <% if @cv %>
      <div>
        <p class="text-[0.75rem] text-subtle uppercase tracking-wider mb-1">Last updated</p>
        <p class="text-sm font-medium text-surface"><%= @cv.updated_at.strftime("%b %-d, %Y") %></p>
      </div>

      <div class="flex-1">
        <p class="text-[0.75rem] text-subtle uppercase tracking-wider mb-1">Preview</p>
        <p class="text-sm text-muted leading-relaxed line-clamp-5">
          <%= truncate(strip_tags(@cv.content), length: 200) %>
        </p>
      </div>

      <div class="mt-auto pt-2 border-t border-border flex gap-3">
        <%= link_to "View CV →", cv_path, class: "text-muted text-[0.8125rem] hover:text-surface transition-colors" %>
      </div>
    <% else %>
      <p class="text-subtle text-sm flex-1">No CV content yet.</p>
      <div class="mt-auto pt-2 border-t border-border">
        <%= link_to "Create CV →", edit_admin_curriculum_vitae_path, class: "text-accent text-[0.8125rem] font-medium hover:text-accent-hover transition-colors" %>
      </div>
    <% end %>
  </div>

  <%# Site Config %>
  <div class="bg-card border border-border rounded-lg p-5 flex flex-col gap-4">
    <div class="flex items-center justify-between">
      <span class="text-xs font-semibold uppercase tracking-wider text-subtle">Site Config</span>
      <%= link_to "Manage →", admin_site_configs_path, class: "text-muted text-[0.75rem] hover:text-surface transition-colors" %>
    </div>

    <div>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-card text-subtle border border-border">
        <%= @site_configs.count %> config<%= "s" if @site_configs.count != 1 %>
      </span>
    </div>

    <div class="flex-1 flex flex-col gap-0">
      <% @site_configs.first(6).each do |config| %>
        <%= link_to edit_admin_site_config_path(config), class: "group flex items-baseline justify-between gap-2 py-1.5 border-b border-border last:border-0 hover:bg-card-hover -mx-2 px-2 rounded transition-colors" do %>
          <span class="text-[0.75rem] font-mono text-muted group-hover:text-surface transition-colors shrink-0"><%= config.key %></span>
          <span class="text-[0.75rem] text-subtle truncate text-right"><%= truncate(config.value.to_s, length: 24) %></span>
        <% end %>
      <% end %>
      <% if @site_configs.count > 6 %>
        <p class="text-[0.75rem] text-subtle mt-1">+<%= @site_configs.count - 6 %> more</p>
      <% end %>
    </div>
  </div>

</div>
