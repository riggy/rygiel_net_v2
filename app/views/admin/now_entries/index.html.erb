<% content_for :title, "Now Entries" %>

<div class="flex items-center justify-between mb-7">
  <h1 class="text-xl font-bold tracking-[-0.02em]">Now</h1>
  <%= link_to "New entry", new_admin_now_entry_path, class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-accent text-white border border-accent hover:bg-accent-hover hover:border-accent-hover" %>
</div>

<% if @now_entries.any? %>
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Content</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border hidden md:table-cell">Created</th>
        <th class="border-b border-border"></th>
      </tr>
    </thead>
    <tbody>
      <% @now_entries.each_with_index do |entry, i| %>
        <tr>
          <td class="p-3.5 border-b border-border text-surface font-medium"><%= truncate(entry.content, length: 80) %></td>
          <td class="p-3.5 border-b border-border text-subtle text-[0.8125rem] hidden md:table-cell">
            <%= entry.created_at.strftime("%b %-d, %Y") %>
            <% if i == 0 %><span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20 ml-2">Current</span><% end %>
          </td>
          <td class="p-3.5 border-b border-border">
            <div class="flex gap-2 justify-end">
              <%= link_to "Edit", edit_admin_now_entry_path(entry), class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-transparent text-surface border border-border-hover hover:border-muted" %>
              <%= button_to "Delete", admin_now_entry_path(entry), method: :delete, class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-transparent text-red-500 border border-[#2a1a1a] hover:bg-[#1a0a0a] hover:border-red-500", data: { turbo_confirm: "Delete this entry?" } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-10">No entries yet. <%= link_to "Create one", new_admin_now_entry_path %>.</p>
<% end %>
