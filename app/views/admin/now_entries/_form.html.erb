<% if now_entry.errors.any? %>
  <div class="form-errors">
    <strong><%= now_entry.errors.count %> <%= "error".pluralize(now_entry.errors.count) %> prevented saving:</strong>
    <ul>
      <% now_entry.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [:admin, now_entry], class: "admin-form" do |f| %>
  <div class="form-group">
    <%= f.label :content, "Now", class: "form-label" %>
    <%= f.text_area :content, class: "form-textarea prose", rows: 6, autofocus: true, placeholder: "What are you working on, reading, learning right now?" %>
  </div>

  <div class="form-actions">
    <%= f.submit now_entry.persisted? ? "Save changes" : "Create entry", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_now_entries_path, class: "btn btn-secondary" %>
  </div>
<% end %>