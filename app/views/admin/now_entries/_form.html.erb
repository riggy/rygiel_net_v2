<% if now_entry.errors.any? %>
  <div class="form-errors">
    <strong><%= now_entry.errors.count %> <%= "error".pluralize(now_entry.errors.count) %> prevented saving:</strong>
    <ul>
      <% now_entry.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [:admin, now_entry], class: "admin-form" do |f| %>
  <div class="form-group">
    <%= f.label :working_on, "Working on", class: "form-label" %>
    <%= f.text_area :working_on, class: "form-textarea prose", rows: 4, autofocus: true, placeholder: "What are you currently working on?" %>
  </div>

  <div class="form-group">
    <%= f.label :reading, class: "form-label" %>
    <%= f.text_field :reading, class: "form-input", placeholder: "Book or article title" %>
  </div>

  <div class="form-group">
    <%= f.label :learning, class: "form-label" %>
    <%= f.text_field :learning, class: "form-input", placeholder: "Technology or skill you're exploring" %>
  </div>

  <div class="form-actions">
    <%= f.submit now_entry.persisted? ? "Save changes" : "Create entry", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_now_entries_path, class: "btn btn-secondary" %>
  </div>
<% end %>