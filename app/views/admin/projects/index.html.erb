<% content_for :title, "Projects" %>

<div class="flex items-center justify-between mb-7">
  <h1 class="text-xl font-bold tracking-[-0.02em]">Projects</h1>
  <%= link_to "New project", new_admin_project_path, class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-accent text-white border border-accent hover:bg-accent-hover hover:border-accent-hover" %>
</div>

<% if @projects.any? %>
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Name</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Tags</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border hidden md:table-cell">Featured</th>
        <th class="border-b border-border"></th>
      </tr>
    </thead>
    <tbody>
      <% @projects.each do |project| %>
        <tr>
          <td class="p-3.5 border-b border-border text-surface font-medium"><%= project.name %></td>
          <td class="p-3.5 border-b border-border text-subtle text-[0.8125rem]"><%= project.tech_tags %></td>
          <td class="p-3.5 border-b border-border text-muted hidden md:table-cell">
            <% if project.featured? %>
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-500/10 text-accent border border-blue-500/20">Featured</span>
            <% else %>
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-card text-subtle border border-border">No</span>
            <% end %>
          </td>
          <td class="p-3.5 border-b border-border">
            <div class="flex gap-2 justify-end">
              <%= link_to "Edit", edit_admin_project_path(project), class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-transparent text-surface border border-border-hover hover:border-muted" %>
              <%= button_to "Delete", admin_project_path(project), method: :delete, class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-transparent text-red-500 border border-[#2a1a1a] hover:bg-[#1a0a0a] hover:border-red-500", data: { turbo_confirm: "Delete \"#{project.name}\"?" } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-10">No projects yet. <%= link_to "Create one", new_admin_project_path %>.</p>
<% end %>
