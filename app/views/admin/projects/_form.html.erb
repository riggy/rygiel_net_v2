<% if project.errors.any? %>
  <div class="form-errors">
    <strong><%= project.errors.count %> <%= "error".pluralize(project.errors.count) %> prevented saving:</strong>
    <ul>
      <% project.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [:admin, project], class: "admin-form" do |f| %>
  <div class="form-group">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-input", autofocus: true, placeholder: "Project name" %>
  </div>

  <div class="form-group">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, class: "form-textarea prose", rows: 4, placeholder: "Short description of the project" %>
  </div>

  <div class="form-group">
    <%= f.label :tech_tags, class: "form-label" do %>
      Tech tags <span class="hint">(comma-separated)</span>
    <% end %>
    <%= f.text_field :tech_tags, class: "form-input", placeholder: "Ruby on Rails, PostgreSQL, Docker" %>
  </div>

  <div class="form-group">
    <%= f.label :url, "URL", class: "form-label" %>
    <%= f.url_field :url, class: "form-input", placeholder: "https://example.com" %>
  </div>

  <div class="form-group">
    <div class="form-checkbox-row">
      <%= f.check_box :featured, class: "form-checkbox" %>
      <%= f.label :featured, "Featured on homepage", class: "form-label", style: "margin-bottom:0" %>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit project.persisted? ? "Save changes" : "Create project", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_projects_path, class: "btn btn-secondary" %>
  </div>
<% end %>