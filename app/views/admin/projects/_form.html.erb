<% if project.errors.any? %>
  <div class="bg-red-500/8 border border-red-500/20 text-red-400 px-4 py-3 rounded text-sm mb-6">
    <strong><%= project.errors.count %> <%= "error".pluralize(project.errors.count) %> prevented saving:</strong>
    <ul class="mt-1.5 ml-4">
      <% project.errors.full_messages.each do |msg| %>
        <li class="mb-1"><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [:admin, project], class: "max-w-[760px]" do |f| %>
  <div class="mb-5">
    <%= f.label :name, class: "block text-[0.8125rem] font-medium text-muted mb-2" %>
    <%= f.text_field :name, class: "w-full bg-card border border-border rounded text-surface font-sans text-sm px-3.5 py-2.5 transition-colors focus:border-accent outline-none", autofocus: true, placeholder: "Project name" %>
  </div>

  <div class="mb-5">
    <%= f.label :description, class: "block text-[0.8125rem] font-medium text-muted mb-2" %>
    <%= f.text_area :description, class: "w-full bg-card border border-border rounded text-surface font-sans text-sm px-3.5 py-2.5 transition-colors focus:border-accent outline-none resize-y min-h-[100px] leading-relaxed", rows: 4, placeholder: "Short description of the project" %>
  </div>

  <div class="mb-5">
    <%= f.label :tech_tags, class: "block text-[0.8125rem] font-medium text-muted mb-2" do %>
      Tech tags <span class="text-subtle font-normal ml-1">(comma-separated)</span>
    <% end %>
    <%= f.text_field :tech_tags, class: "w-full bg-card border border-border rounded text-surface font-sans text-sm px-3.5 py-2.5 transition-colors focus:border-accent outline-none", placeholder: "Ruby on Rails, PostgreSQL, Docker" %>
  </div>

  <div class="mb-5">
    <%= f.label :url, "URL", class: "block text-[0.8125rem] font-medium text-muted mb-2" %>
    <%= f.url_field :url, class: "w-full bg-card border border-border rounded text-surface font-sans text-sm px-3.5 py-2.5 transition-colors focus:border-accent outline-none", placeholder: "https://example.com" %>
  </div>

  <div class="mb-5">
    <div class="flex items-center gap-2.5">
      <%= f.check_box :featured, class: "w-4 h-4 accent-accent cursor-pointer" %>
      <%= f.label :featured, "Featured on homepage", class: "block text-[0.8125rem] font-medium text-muted" %>
    </div>
  </div>

  <div class="flex items-center gap-3 mt-7 pt-7 border-t border-border">
    <%= f.submit project.persisted? ? "Save changes" : "Create project", class: "inline-flex items-center px-5 py-2.5 rounded text-sm font-medium transition-all duration-150 bg-accent text-white border border-accent hover:bg-accent-hover hover:border-accent-hover cursor-pointer" %>
    <%= link_to "Cancel", admin_projects_path, class: "inline-flex items-center px-5 py-2.5 rounded text-sm font-medium transition-all duration-150 bg-transparent text-surface border border-border-hover hover:border-muted" %>
  </div>
<% end %>
