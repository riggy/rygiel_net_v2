<% content_for :title, "Analytics" %>

<div class="mb-7">
  <h1 class="text-xl font-bold tracking-[-0.02em]">Analytics</h1>
</div>

<%# Summary cards %>
<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="rounded-lg border border-border bg-card p-5">
    <p class="text-subtle text-xs uppercase tracking-wider mb-1">Today</p>
    <p class="text-2xl font-bold text-surface"><%= @total_today %></p>
  </div>
  <div class="rounded-lg border border-border bg-card p-5">
    <p class="text-subtle text-xs uppercase tracking-wider mb-1">This Week</p>
    <p class="text-2xl font-bold text-surface"><%= @total_week %></p>
  </div>
  <div class="rounded-lg border border-border bg-card p-5">
    <p class="text-subtle text-xs uppercase tracking-wider mb-1">This Month</p>
    <p class="text-2xl font-bold text-surface"><%= @total_month %></p>
  </div>
</div>

<%# Top pages %>
<h2 class="text-sm font-semibold text-surface uppercase tracking-wider mb-3">Top Pages (last 30 days)</h2>
<% if @top_pages.any? %>
  <table class="w-full border-collapse text-sm mb-8">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Path</th>
        <th class="text-right p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Views</th>
      </tr>
    </thead>
    <tbody>
      <% @top_pages.each do |path, count| %>
        <tr>
          <td class="p-3.5 border-b border-border text-surface font-medium"><%= path %></td>
          <td class="p-3.5 border-b border-border text-muted text-right"><%= count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-4 mb-8">No data yet.</p>
<% end %>

<%# Top referrers %>
<h2 class="text-sm font-semibold text-surface uppercase tracking-wider mb-3">Top Referrers (last 30 days)</h2>
<% if @top_referrers.any? %>
  <table class="w-full border-collapse text-sm mb-8">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Referrer</th>
        <th class="text-right p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Views</th>
      </tr>
    </thead>
    <tbody>
      <% @top_referrers.each do |referer, count| %>
        <tr>
          <td class="p-3.5 border-b border-border text-surface font-medium break-all"><%= referer %></td>
          <td class="p-3.5 border-b border-border text-muted text-right"><%= count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-4 mb-8">No referrer data yet.</p>
<% end %>

<%# Recent visits %>
<h2 class="text-sm font-semibold text-surface uppercase tracking-wider mb-3">Recent Visits</h2>
<% if @recent.any? %>
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Path</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border hidden md:table-cell">IP</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border hidden md:table-cell">Session</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border hidden lg:table-cell">Trace ID</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border hidden lg:table-cell">Referrer</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Time</th>
      </tr>
    </thead>
    <tbody>
      <% @recent.each do |pv| %>
        <tr>
          <td class="p-3.5 border-b border-border text-surface font-medium"><%= pv.path %></td>
          <td class="p-3.5 border-b border-border text-muted hidden md:table-cell"><%= pv.visitor&.ip %></td>
          <td class="p-3.5 border-b border-border text-muted hidden md:table-cell font-mono text-xs"><%= pv.session_id.presence&.first(8) || "—" %></td>
          <td class="p-3.5 border-b border-border text-muted hidden lg:table-cell font-mono text-xs"><%= pv.trace_id.presence || "—" %></td>
          <td class="p-3.5 border-b border-border text-muted hidden lg:table-cell break-all"><%= pv.referer.presence || "—" %></td>
          <td class="p-3.5 border-b border-border text-muted text-sm"><%= pv.created_at.strftime("%b %-d, %H:%M") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-4">No visits recorded yet.</p>
<% end %>
