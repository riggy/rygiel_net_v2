<% if post.errors.any? %>
  <div class="form-errors">
    <strong><%= post.errors.count %> <%= "error".pluralize(post.errors.count) %> prevented saving:</strong>
    <ul>
      <% post.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [:admin, post], class: "admin-form" do |f| %>
  <div class="form-group">
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-input", autofocus: true, placeholder: "Post title" %>
  </div>

  <div class="form-group">
    <%= f.label :body, class: "form-label" do %>
      Body <span class="hint">(Markdown)</span>
    <% end %>
    <%= f.text_area :body, class: "form-textarea", rows: 20, placeholder: "Write in Markdown..." %>
  </div>

  <div class="form-group">
    <div class="form-checkbox-row">
      <%= f.check_box :published, class: "form-checkbox" %>
      <%= f.label :published, "Published", class: "form-label" style: "margin-bottom:0" %>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit post.persisted? ? "Save changes" : "Create post", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_posts_path, class: "btn btn-secondary" %>
  </div>
<% end %>