<% content_for :title, "Posts" %>

<div class="admin-page-header">
  <h1 class="admin-page-title">Posts</h1>
  <%= link_to "New post", new_admin_post_path, class: "btn btn-primary btn-sm" %>
</div>

<% if @posts.any? %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Status</th>
        <th>Published</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @posts.each do |post| %>
        <tr>
          <td><%= post.title %></td>
          <td>
            <% if post.published? %>
              <span class="badge badge-published">Published</span>
            <% else %>
              <span class="badge badge-draft">Draft</span>
            <% end %>
          </td>
          <td><%= post.published_at&.strftime("%b %-d, %Y") || "—" %></td>
          <td>
            <div class="admin-table-actions">
              <%= link_to "Edit", edit_admin_post_path(post), class: "btn btn-secondary btn-sm" %>
              <%= button_to "Delete", admin_post_path(post), method: :delete, class: "btn btn-danger btn-sm", data: { turbo_confirm: "Delete \"#{post.title}?\"" } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty-state">No posts yet. <%= link_to "Create one", new_admin_post_path %>.</p>
<% end %>