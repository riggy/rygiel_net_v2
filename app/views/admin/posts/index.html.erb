<% content_for :title, "Posts" %>

<div class="flex items-center justify-between mb-7">
  <h1 class="text-xl font-bold tracking-[-0.02em]">Posts</h1>
  <%= link_to "New post", new_admin_post_path, class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-accent text-white border border-accent hover:bg-accent-hover hover:border-accent-hover" %>
</div>

<% if @posts.any? %>
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Title</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Status</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border hidden md:table-cell">Published</th>
        <th class="border-b border-border"></th>
      </tr>
    </thead>
    <tbody>
      <% @posts.each do |post| %>
        <tr>
          <td class="p-3.5 border-b border-border text-surface font-medium"><%= post.title %></td>
          <td class="p-3.5 border-b border-border text-muted">
            <% if post.published? %>
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">Published</span>
            <% else %>
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-card text-subtle border border-border">Draft</span>
            <% end %>
          </td>
          <td class="p-3.5 border-b border-border text-muted hidden md:table-cell"><%= post.published_at&.strftime("%b %-d, %Y") || "—" %></td>
          <td class="p-3.5 border-b border-border">
            <div class="flex gap-2 justify-end">
              <%= link_to "Edit", edit_admin_post_path(post), class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-transparent text-surface border border-border-hover hover:border-muted" %>
              <%= button_to "Delete", admin_post_path(post), method: :delete, class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-transparent text-red-500 border border-[#2a1a1a] hover:bg-[#1a0a0a] hover:border-red-500", data: { turbo_confirm: "Delete \"#{post.title}?\"" } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-10">No posts yet. <%= link_to "Create one", new_admin_post_path %>.</p>
<% end %>
