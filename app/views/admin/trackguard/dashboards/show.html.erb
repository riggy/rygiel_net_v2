<% content_for :title, "Trackguard" %>

<div class="mb-7">
  <h1 class="text-xl font-bold tracking-[-0.02em]">Trackguard</h1>
</div>

<%# Summary cards %>
<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="rounded-lg border border-border bg-card p-5">
    <p class="text-subtle text-xs uppercase tracking-wider mb-1">Today</p>
    <p class="text-2xl font-bold text-surface"><%= @total_today %></p>
  </div>
  <div class="rounded-lg border border-border bg-card p-5">
    <p class="text-subtle text-xs uppercase tracking-wider mb-1">This Week</p>
    <p class="text-2xl font-bold text-surface"><%= @total_week %></p>
  </div>
  <div class="rounded-lg border border-border bg-card p-5">
    <p class="text-subtle text-xs uppercase tracking-wider mb-1">This Month</p>
    <p class="text-2xl font-bold text-surface"><%= @total_month %></p>
  </div>
</div>

<%# Top pages %>
<h2 class="text-sm font-semibold text-surface uppercase tracking-wider mb-3">Top Pages (last 30 days)</h2>
<% if @top_pages.any? %>
  <table class="w-full border-collapse text-sm mb-8">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Path</th>
        <th class="text-right p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Views</th>
      </tr>
    </thead>
    <tbody>
      <% @top_pages.each do |path, count| %>
        <tr>
          <td class="p-3.5 border-b border-border text-surface font-medium"><%= path %></td>
          <td class="p-3.5 border-b border-border text-muted text-right"><%= count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-4 mb-8">No data yet.</p>
<% end %>

<%# Top referrers %>
<h2 class="text-sm font-semibold text-surface uppercase tracking-wider mb-3">Top Referrers (last 30 days)</h2>
<% if @top_referrers.any? %>
  <table class="w-full border-collapse text-sm mb-8">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Referrer</th>
        <th class="text-right p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Views</th>
      </tr>
    </thead>
    <tbody>
      <% @top_referrers.each do |referer, count| %>
        <tr>
          <td class="p-3.5 border-b border-border text-surface font-medium break-all"><%= referer %></td>
          <td class="p-3.5 border-b border-border text-muted text-right"><%= count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-4 mb-8">No referrer data yet.</p>
<% end %>

<%# Top sources %>
<h2 class="text-sm font-semibold text-surface uppercase tracking-wider mb-3">Top Sources (last 30 days)</h2>
<% if @top_sources.any? %>
  <table class="w-full border-collapse text-sm mb-8">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Source</th>
        <th class="text-right p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Views</th>
      </tr>
    </thead>
    <tbody>
      <% @top_sources.each do |source, count| %>
        <tr>
          <td class="p-3.5 border-b border-border text-surface font-medium"><%= source %></td>
          <td class="p-3.5 border-b border-border text-muted text-right"><%= count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-4 mb-8">No source data yet.</p>
<% end %>

<%# Recent visits %>
<h2 class="text-sm font-semibold text-surface uppercase tracking-wider mb-3">Recent Visits</h2>
<% if @recent.any? %>
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Path</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">IP</th>
        <th class="text-center p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border w-10">Flag</th>
        <th class="text-left p-3.5 text-subtle text-xs uppercase tracking-wider border-b border-border">Time</th>
        <th class="p-3.5 border-b border-border w-8"></th>
      </tr>
    </thead>
    <tbody data-controller="visit-detail">
      <% @recent.each do |pv| %>
        <% visitor = pv.visitor %>
        <% flagged = visitor&.flagged_at.present? %>
        <tr class="<%= flagged ? 'bg-red-950/20' : '' %>">
          <td class="p-3.5 border-b border-border text-surface font-medium"><%= pv.path %></td>
          <td class="p-3.5 border-b border-border text-muted font-mono text-xs"><%= visitor&.ip || "—" %></td>
          <td class="p-3.5 border-b border-border text-center">
            <% if flagged %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-red-500 inline-block" title="Flagged">
                <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
              </svg>
            <% else %>
              <span class="text-subtle">—</span>
            <% end %>
          </td>
          <td class="p-3.5 border-b border-border text-muted text-sm"><%= pv.created_at.strftime("%b %-d, %H:%M") %></td>
          <td class="p-3.5 border-b border-border text-center">
            <button data-action="click->visit-detail#toggle" class="text-subtle hover:text-accent transition-colors cursor-pointer" title="Show details">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
              </svg>
            </button>
          </td>
        </tr>
        <tr class="hidden">
          <td colspan="5" class="px-4 pb-4 border-b border-border bg-card">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-3">
              <div>
                <p class="text-subtle text-xs uppercase tracking-wider mb-2">Visitor</p>
                <dl class="space-y-1 text-xs">
                  <div class="flex gap-2">
                    <dt class="text-subtle w-24 shrink-0">IP</dt>
                    <dd class="text-muted font-mono"><%= visitor&.ip || "—" %></dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="text-subtle w-24 shrink-0">First seen</dt>
                    <dd class="text-muted"><%= visitor&.first_seen_at&.strftime("%b %-d %Y, %H:%M") || "—" %></dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="text-subtle w-24 shrink-0">Last seen</dt>
                    <dd class="text-muted"><%= visitor&.last_seen_at&.strftime("%b %-d %Y, %H:%M") || "—" %></dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="text-subtle w-24 shrink-0">User agent</dt>
                    <dd class="text-muted break-all"><%= visitor&.user_agent.presence || "—" %></dd>
                  </div>
                  <div class="flex gap-2 pt-1">
                    <dt class="text-subtle w-24 shrink-0">Flag status</dt>
                    <% if flagged %>
                      <dd class="text-red-400">
                        Flagged <%= visitor.flagged_at.strftime("%b %-d %Y, %H:%M") %>
                        <% if visitor.flagged_by.present? %> by <span class="font-medium"><%= visitor.flagged_by %></span><% end %>
                        <% if visitor.flag_reason.present? %> — <%= visitor.flag_reason %><% end %>
                      </dd>
                    <% else %>
                      <dd class="text-subtle">Not flagged</dd>
                    <% end %>
                  </div>
                </dl>
              </div>
              <div>
                <p class="text-subtle text-xs uppercase tracking-wider mb-2">This Visit</p>
                <dl class="space-y-1 text-xs">
                  <div class="flex gap-2">
                    <dt class="text-subtle w-24 shrink-0">Session</dt>
                    <dd class="text-muted font-mono break-all"><%= pv.session_id.presence || "—" %></dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="text-subtle w-24 shrink-0">Trace ID</dt>
                    <dd class="text-muted font-mono break-all"><%= pv.trace_id.presence || "—" %></dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="text-subtle w-24 shrink-0">Referrer</dt>
                    <dd class="text-muted break-all"><%= pv.referer.presence || "—" %></dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="text-subtle w-24 shrink-0">Source</dt>
                    <dd class="text-muted"><%= pv.source.presence || "—" %></dd>
                  </div>
                </dl>
              </div>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-subtle text-[0.9375rem] py-4">No visits recorded yet.</p>
<% end %>
