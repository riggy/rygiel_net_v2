<% content_for :title, "Krzysztof Rygielski — Developer" %>

<section class="min-h-screen flex items-center border-b border-border">
  <div class="max-w-[1100px] mx-auto px-6">
    <h1 class="text-hero font-bold tracking-[-0.035em] leading-[1.02] mb-5">Krzysztof Rygielski</h1>
    <p class="text-muted mb-10 max-w-[540px] leading-relaxed">Software developer building clean, reliable things for the web.</p>
    <div class="flex gap-3.5 flex-wrap">
      <%= link_to "View Work", "#projects", class: "inline-flex items-center px-5 py-2.5 rounded text-sm font-medium transition-all duration-150 bg-accent text-white border border-accent hover:bg-accent-hover hover:border-accent-hover" %>
      <%= link_to "Get in Touch", "#contact", class: "inline-flex items-center px-5 py-2.5 rounded text-sm font-medium transition-all duration-150 bg-transparent text-surface border border-border-hover hover:border-muted" %>
    </div>
  </div>
</section>

<section id="about" class="py-20 border-b border-border">
  <div class="max-w-[1100px] mx-auto px-6">
    <p class="text-[0.6875rem] font-semibold tracking-[0.12em] uppercase text-label mb-10">About</p>
    <div class="max-w-[680px] text-[1.0625rem] leading-[1.8] text-muted">
      <p>I'm a software developer with a focus on backend systems and web applications. I enjoy working close to the metal — clean architecture, fast deployments, and tools that stay out of the way.</p>
      <p class="mt-5">Currently building with Ruby on Rails, leaning on modern defaults: SQLite, Solid Queue, Kamal. I believe in shipping small, iterating fast, and keeping complexity budget under control.</p>
    </div>
  </div>
</section>

<section id="skills" class="py-20 border-b border-border">
  <div class="max-w-[1100px] mx-auto px-6">
    <p class="text-[0.6875rem] font-semibold tracking-[0.12em] uppercase text-label mb-10">Skills</p>
    <div class="flex flex-wrap gap-2 max-w-[700px]">
      <% %w[Ruby Rails PostgreSQL SQLite Docker Linux Git REST\ APIs Hotwire Stimulus Kamal RSpec].each do |skill| %>
        <span class="bg-card border border-border text-muted px-3.5 py-1.5 rounded-full text-[0.8125rem] font-medium"><%= skill %></span>
      <% end %>
    </div>
  </div>
</section>

<section id="projects" class="py-20 border-b border-border">
  <div class="max-w-[1100px] mx-auto px-6">
    <p class="text-[0.6875rem] font-semibold tracking-[0.12em] uppercase text-label mb-10">Projects</p>
    <% if @projects.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-4">
        <% @projects.each do |project| %>
          <div class="bg-card border border-border rounded-lg p-6 flex flex-col gap-3 hover:border-border-hover transition-colors duration-150">
            <div class="flex items-start justify-between gap-4">
              <span class="text-[0.9375rem] font-semibold text-surface"><%= project.name %></span>
              <% if project.url.present? %>
                <%= link_to "↗", project.url, class: "text-subtle no-underline text-[0.8125rem] transition-colors duration-150 hover:text-accent whitespace-nowrap", target: "_blank", rel: "noopener noreferrer" %>
              <% end %>
            </div>
            <p class="text-sm text-muted leading-[1.65] flex-1"><%= project.description %></p>
            <% if project.tag_list.any? %>
              <div class="flex flex-wrap gap-1.5">
                <% project.tag_list.each do |tag| %>
                  <span class="text-xs text-accent bg-blue-500/10 border border-blue-500/20 px-2.5 py-0.5 rounded-full"><%= tag %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-subtle text-[0.9375rem] py-10">Projects coming soon.</p>
    <% end %>
  </div>
</section>

<section id="blog" class="py-20 border-b border-border">
  <div class="max-w-[1100px] mx-auto px-6">
    <p class="text-[0.6875rem] font-semibold tracking-[0.12em] uppercase text-label mb-10">Blog</p>
    <% if @posts.any? %>
      <div class="flex flex-col gap-3.5 max-w-[760px]">
        <% @posts.each do |post| %>
          <%= link_to blog_post_path(post), class: "bg-card border border-border rounded-lg px-6 py-5 block no-underline hover:border-border-hover transition-colors duration-150" do %>
            <p class="text-[0.9375rem] font-semibold mb-1.5 text-surface"><%= post.title %></p>
            <p class="text-[0.8125rem] text-subtle"><%= post.published_at&.strftime("%B %-d, %Y") %></p>
          <% end %>
        <% end %>
      </div>
      <div class="mt-6">
        <%= link_to "All posts →", blog_path, class: "inline-flex items-center px-3.5 py-1.5 rounded text-[0.8125rem] font-medium transition-all duration-150 bg-transparent text-surface border border-border-hover hover:border-muted" %>
      </div>
    <% else %>
      <p class="text-subtle text-[0.9375rem] py-10">No posts yet.</p>
    <% end %>
  </div>
</section>

<section id="now" class="py-20 border-b border-border">
  <div class="max-w-[1100px] mx-auto px-6">
    <p class="text-[0.6875rem] font-semibold tracking-[0.12em] uppercase text-label mb-10">Now</p>
    <% if @now_entry %>
      <p class="max-w-[680px] text-[1.0625rem] leading-[1.8] text-muted"><%= @now_entry.content %></p>
    <% else %>
      <p class="text-subtle text-[0.9375rem] py-10">Nothing here yet.</p>
    <% end %>
  </div>
</section>

<section id="contact" class="py-20">
  <div class="max-w-[1100px] mx-auto px-6">
    <p class="text-[0.6875rem] font-semibold tracking-[0.12em] uppercase text-label mb-10">Contact</p>
    <p class="text-muted mb-7 max-w-[500px] text-[1.0625rem] leading-[1.7]">Open to interesting projects and conversations. Reach out via email or find me online.</p>
    <div class="flex gap-5 flex-wrap">
      <a href="mailto:hello@rygiel.net" class="text-muted text-sm font-medium no-underline hover:text-surface border-b border-transparent hover:border-border-hover transition-colors duration-150">hello@rygiel.net</a>
      <a href="https://github.com/" class="text-muted text-sm font-medium no-underline hover:text-surface border-b border-transparent hover:border-border-hover transition-colors duration-150" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://linkedin.com/" class="text-muted text-sm font-medium no-underline hover:text-surface border-b border-transparent hover:border-border-hover transition-colors duration-150" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </div>
  </div>
</section>
