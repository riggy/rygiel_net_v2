<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "Krzysztof Rygielski — Developer" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || "Personal homepage and blog of Krzysztof Rygielski, a software developer." %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="trace-id" content="<%= @trace_id %>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.svg">
    <link rel="manifest" href="/manifest.json">


    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-bg text-surface antialiased" data-controller="page-tracker">
    <nav class="fixed top-0 inset-x-0 z-50 bg-[rgba(7,16,31,0.85)] backdrop-blur-md border-b border-border">
      <div class="max-w-[1100px] mx-auto px-6 h-[60px] flex items-center justify-between">
        <%= link_to "KR", root_path, class: "font-bold tracking-widest text-surface no-underline" %>
        <ul class="hidden sm:flex list-none gap-8 m-0 p-0 items-center">
          <li><a href="/#about" data-turbo="false"data-turbo="false" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">About</a></li>
          <li><a href="/#skills" data-turbo="false" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">Skills</a></li>
          <li><a href="/#projects" data-turbo="false" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">Projects</a></li>
          <li><a href="/#blog" data-turbo="false" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">Blog</a></li>
          <li><a href="/#now" data-turbo="false" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">Now</a></li>
          <li><%= link_to "CV", cv_path, class: "text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200" %></li>
          <li><a href="/#contact" data-turbo="false" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">Contact</a></li>
        </ul>
      </div>
    </nav>

    <%= yield %>

    <% if Flipper.enabled?(:ai_chatbot) %>
    <div class="chat-widget" data-controller="chat">
      <button class="chat-widget__trigger" data-action="click->chat#toggle" type="button" aria-label="Open chat">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
        <span>Chat</span>
      </button>
      <div class="chat-widget__panel hidden">
        <div class="chat-widget__header">
          <span class="text-surface text-sm font-medium">Ask Krzysztof's AI</span>
        </div>
        <%= turbo_frame_tag "chat_panel", src: new_conversation_path do %>
          <div class="chat-widget__loading text-muted text-xs p-4">Loading…</div>
        <% end %>
      </div>
    </div>
    <% end %>

    <footer class="py-8 border-t border-border text-subtle text-[0.8125rem]">
      <div class="max-w-[1100px] mx-auto px-6">
        <div class="flex items-center justify-between gap-4">
          <p>&copy; <%= Time.current.year %> Krzysztof Rygielski</p>
          <p class="text-subtle text-[0.75rem] text-right">
            This site uses server-side access logs for basic analytics. No third-party tracking. A functional session cookie may be set by the server.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
