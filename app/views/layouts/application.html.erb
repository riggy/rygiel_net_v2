<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "Krzysztof Rygielski — Developer" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || "Personal homepage and blog of Krzysztof Rygielski, a software developer." %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-bg text-surface antialiased">
    <nav class="fixed top-0 inset-x-0 z-50 bg-[rgba(7,16,31,0.85)] backdrop-blur-md border-b border-border">
      <div class="max-w-[1100px] mx-auto px-6 h-[60px] flex items-center justify-between">
        <%= link_to "KR", root_path, class: "font-bold tracking-widest text-surface no-underline" %>
        <ul class="hidden sm:flex list-none gap-8 m-0 p-0 items-center">
          <li><a href="/#about" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">About</a></li>
          <li><a href="/#skills" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">Skills</a></li>
          <li><a href="/#projects" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">Projects</a></li>
          <li><a href="/#blog" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">Blog</a></li>
          <li><a href="/#now" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">Now</a></li>
          <li><a href="/#contact" class="text-muted text-[0.8125rem] font-medium no-underline hover:text-accent hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.55)] transition-all duration-200">Contact</a></li>
        </ul>
      </div>
    </nav>

    <%= yield %>

    <footer class="py-8 border-t border-border text-subtle text-[0.8125rem]">
      <div class="max-w-[1100px] mx-auto px-6">
        <p>&copy; <%= Time.current.year %> Krzysztof Rygielski</p>
      </div>
    </footer>
  </body>
</html>
