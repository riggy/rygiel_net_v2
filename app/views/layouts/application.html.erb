<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Krzysztof Rygielski — Developer" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || "Personal homepage and blog of Krzysztof Rygielski, a software developer." %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="nav">
      <div class="nav-container">
        <%= link_to "DR", root_path, class: "nav-logo" %>
        <ul class="nav-links">
          <li><a href="/#about">About</a></li>
          <li><a href="/#skills">Skills</a></li>
          <li><a href="/#projects">Projects</a></li>
          <li><a href="/#blog">Blog</a></li>
          <li><a href="/#now">Now</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>
      </div>
    </nav>

    <%= yield %>

    <footer class="footer">
      <div class="container">
        <p>&copy; <%= Time.current.year %> Krzysztof Rygielski</p>
      </div>
    </footer>
  </body>
</html>