<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "CV" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <style>
      body {
        max-width: 780px;
        margin: 1.5rem auto;
        padding: 0 2rem;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 10pt;
        line-height: 1.45;
        background: white;
        color: #111;
      }

      .post-body {
        color: #111;
        font-size: 10pt;
        line-height: 1.45;
        padding: 0;
        max-width: none;
      }

      /* Name */
      .post-body h1 {
        font-size: 30pt;
        font-weight: 700;
        color: #444;
        letter-spacing: normal;
        margin: 0 0 0.15rem;
        text-transform: uppercase;
      }

      /* Role / title line */
      .post-body h2 {
        font-size: 15pt;
        font-weight: 700;
        color: #111;
        letter-spacing: normal;
        margin: 0 0 0.4rem;
        text-transform: uppercase;
      }

      /* Section headers — flanked by horizontal rules */
      .post-body h3 {
        font-size: 10pt;
        font-weight: 700;
        color: #555;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        border-top: 1px solid #999;
        border-bottom: 1px solid #999;
        padding: 0.25rem 0;
        margin: 1.1rem 0 0.6rem;
      }

      /* Job title / sub-section */
      .post-body h4 {
        font-size: 10pt;
        font-weight: 700;
        color: #111;
        letter-spacing: normal;
        margin: 0.7rem 0 0.1rem;
      }

      .post-body p   { margin-bottom: 0.5rem; }
      .post-body ul,
      .post-body ol  { margin: 0.25rem 0 0.5rem 1.2rem; }
      .post-body li  { margin-bottom: 0.15rem; }

      .post-body a        { color: #1a6af5; }
      .post-body code     { background: #f5f5f5; border-color: #ddd; color: #333; }
      .post-body pre      { background: #f5f5f5; border-color: #ddd; }
      .post-body pre code { color: #333; }
      .post-body blockquote { border-left-color: #555; color: #333; }
      .post-body th       { background: #f5f5f5; color: #111; }
      .post-body td,
      .post-body th       { border-color: #ddd; }

      @media print {
        @page { margin: 1.5cm 2cm; }
        body  { max-width: none; margin: 0; padding: 0; }
        a     { color: #1a6af5; text-decoration: none; }
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
