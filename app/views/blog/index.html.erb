<% content_for :title, "Blog — Krzysztof Rygielski" %>

<div class="pt-32 pb-14 border-b border-border">
  <div class="max-w-[1100px] mx-auto px-6">
    <h1 class="text-page-h font-bold tracking-tight mb-2">Blog</h1>
    <p class="text-muted text-[0.9375rem]"><%= @total %> <%= "post".pluralize(@total) %></p>
  </div>
</div>

<div class="py-12 pb-20">
  <div class="max-w-[1100px] mx-auto px-6">
    <% if @posts.any? %>
      <div class="max-w-[760px] flex flex-col gap-3.5">
        <% @posts.each do |post| %>
          <%= link_to blog_post_path(post), class: "bg-card border border-border rounded-lg px-6 py-5 block no-underline hover:border-border-hover transition-colors duration-150" do %>
            <p class="text-[0.9375rem] font-semibold mb-1.5 text-surface"><%= post.title %></p>
            <p class="text-[0.8125rem] text-subtle"><%= post.published_at&.strftime("%B %-d, %Y") %></p>
          <% end %>
        <% end %>
      </div>

      <% if @total_pages > 1 %>
        <nav class="flex items-center gap-1.5 mt-10">
          <% if @page > 1 %>
            <%= link_to "←", blog_path(page: @page - 1), class: "inline-flex items-center justify-center min-w-[2.25rem] px-2.5 py-1.5 rounded text-sm no-underline border border-border text-muted transition-all duration-150 hover:border-accent hover:text-accent" %>
          <% else %>
            <span class="inline-flex items-center justify-center min-w-[2.25rem] px-2.5 py-1.5 rounded text-sm border border-border text-muted opacity-25 pointer-events-none">←</span>
          <% end %>

          <% (1..@total_pages).each do |p| %>
            <% if p == @page %>
              <span class="inline-flex items-center justify-center min-w-[2.25rem] px-2.5 py-1.5 rounded text-sm border border-accent bg-accent text-white"><%= p %></span>
            <% else %>
              <%= link_to p, blog_path(page: p), class: "inline-flex items-center justify-center min-w-[2.25rem] px-2.5 py-1.5 rounded text-sm no-underline border border-border text-muted transition-all duration-150 hover:border-accent hover:text-accent" %>
            <% end %>
          <% end %>

          <% if @page < @total_pages %>
            <%= link_to "→", blog_path(page: @page + 1), class: "inline-flex items-center justify-center min-w-[2.25rem] px-2.5 py-1.5 rounded text-sm no-underline border border-border text-muted transition-all duration-150 hover:border-accent hover:text-accent" %>
          <% else %>
            <span class="inline-flex items-center justify-center min-w-[2.25rem] px-2.5 py-1.5 rounded text-sm border border-border text-muted opacity-25 pointer-events-none">→</span>
          <% end %>
        </nav>
      <% end %>
    <% else %>
      <p class="text-subtle text-[0.9375rem] py-10">No posts published yet.</p>
    <% end %>
  </div>
</div>
