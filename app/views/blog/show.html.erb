<% content_for :title, "#{@post.title} — Krzysztof Rygielski" %>
<% content_for :description, @post.title %>

<div class="post-header">
  <div class="container">
    <%= link_to "← Blog", blog_path, class: "back-link" %>
    <div class="post-header-inner">
      <h1 class="post-title"><%= @post.title %></h1>
      <p class="post-meta"><%= @post.published_at&.strftime("%B %-d, %Y") %></p>
    </div>
  </div>
</div>

<div class="container">
  <div class="post-body">
    <%= markdown(@post.body) %>
  </div>
</div>